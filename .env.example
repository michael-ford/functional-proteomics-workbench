# --- core ---
DATABASE_URL=
APP_BASE_URL=
FPW_API_BASE_URL=http://127.0.0.1:8000
MCP_DEMO_TOKEN=

# --- model providers ---
MODEL_PROVIDER=openrouter
FPW_USE_MOCK_MODEL=false             # true for deterministic local/CI chat fallback
OPENROUTER_API_KEY=               # drives the agent loop (Kimi via OpenRouter)
OPENROUTER_MODEL=moonshotai/kimi-k2
OPENAI_API_KEY=                   # optional / evals only
ANTHROPIC_API_KEY=                # optional / evals only

# --- artifact storage: local FS (dev) / Railway volume (deploy); object storage deferred ---
ARTIFACT_ROOT=./.artifacts        # dev path the storage adapter writes project:// URIs under

RAILWAY_ENVIRONMENT=
PORT=8000
